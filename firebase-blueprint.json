{
  "entities": {
    "User": {
      "title": "User",
      "description": "A player of London Bleeds.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Investigation": {
      "title": "Investigation",
      "description": "The top-level container for a game session.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "UID of the lead investigator" },
        "status": { "type": "string", "enum": ["active", "cold_case", "solved", "archived"] },
        "currentLocation": { "type": "string" },
        "sanity": { "type": "number" },
        "globalFlags": { "type": "object", "description": "World-wide triggers and states" },
        "journalNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "status", "currentLocation", "sanity", "globalFlags", "createdAt", "updatedAt"]
    },
    "LocationState": {
      "title": "Location State",
      "description": "Mutations and persistent changes to a specific game location.",
      "type": "object",
      "properties": {
        "locationId": { "type": "string" },
        "isCrimeScene": { "type": "boolean" },
        "isLocked": { "type": "boolean" },
        "mutations": { "type": "object", "description": "Arbitrary state changes (e.g., 'window_broken': true)" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["locationId", "updatedAt"]
    },
    "NPCState": {
      "title": "NPC State",
      "description": "Dynamic status and disposition of a non-player character.",
      "type": "object",
      "properties": {
        "npcId": { "type": "string" },
        "disposition": { "type": "number", "description": "Relationship score (0-100)" },
        "currentLocation": { "type": "string" },
        "status": { "type": "string", "description": "e.g., 'alive', 'deceased', 'missing', 'hostile'" },
        "lastInteraction": { "type": "string", "format": "date-time" }
      },
      "required": ["npcId", "disposition", "status"]
    },
    "Clue": {
      "title": "Clue",
      "description": "A piece of evidence discovered during the investigation.",
      "type": "object",
      "properties": {
        "clueId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "discoveredAt": { "type": "string", "format": "date-time" },
        "locationFound": { "type": "string" },
        "connections": { "type": "array", "items": { "type": "string" }, "description": "IDs of related clues/NPCs" }
      },
      "required": ["clueId", "name", "description", "discoveredAt"]
    },
    "LogEntry": {
      "title": "Log Entry",
      "description": "A single narrative beat or player action in the investigation history.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["narration", "action", "dialogue", "system"] },
        "content": { "type": "string" },
        "speaker": { "type": "string", "description": "Optional: Name of the NPC or 'Player'" }
      },
      "required": ["timestamp", "type", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile information."
    },
    "/investigations/{investigationId}": {
      "schema": "Investigation",
      "description": "Active investigation case files."
    },
    "/investigations/{investigationId}/locations/{locationId}": {
      "schema": "LocationState",
      "description": "Persistent state for specific locations within a case."
    },
    "/investigations/{investigationId}/npcs/{npcId}": {
      "schema": "NPCState",
      "description": "Dynamic status of characters within a case."
    },
    "/investigations/{investigationId}/clues/{clueId}": {
      "schema": "Clue",
      "description": "Evidence locker for the investigation."
    },
    "/investigations/{investigationId}/log/{logId}": {
      "schema": "LogEntry",
      "description": "Chronological history of the investigation."
    }
  }
}
